# Backend API Configuration
PORT=3001

# Trello API Credentials
# Get your API key and token from: https://trello.com/app-key
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here

# The ID of the Trello list containing meals selected for the current week
TRELLO_WEEKLY_LIST_ID=your_trello_list_id_here

# Comma-separated list of Trello list IDs to use as meal sources (shown below the weekly meals)
TRELLO_MEAL_SOURCE_LIST_IDS=list_id_1,list_id_2
